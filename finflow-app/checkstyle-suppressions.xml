<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<!--
    Suppressions for the few cases where google-java-format (applied via the
    Spotless plugin) produces output that the standalone google_checks.xml flags.
    The auto-formatter owns code layout, so these formatting-only checks defer to it.
-->
<suppressions>
    <!-- google-java-format keeps parameter annotations on one line and does not
         wrap them, so an annotated record component can exceed the 100-char limit. -->
    <suppress checks="LineLength"
              files="expense[\\/]api[\\/]dto[\\/]CreateExpenseRequest\.java"/>

    <!-- google-java-format collapses an empty class body to "{}", which
         RightCurly (option=alone) reports. -->
    <suppress id="RightCurlyAlone"
              files="expense[\\/]api[\\/]ExpenseController\.java"/>
</suppressions>
